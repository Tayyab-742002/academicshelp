{
  "functions": {
    "app/api/contact/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/(.*).(js|css|xml|jpeg|jpg|png|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://muhammadtayyab.dev/$1",
      "permanent": true
    },
    {
      "source": "/academic-help",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/homework-help",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/assignment-help",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/essay-writing",
      "destination": "/services/essay-writing",
      "permanent": true
    }
  ]
} 
